                        "title": "Email"
                    },
                    "username": {
                        "type": "string",
                        "maxLength": 30,
                        "minLength": 3,
                        "title": "Username"
                    }
                },
                "type": "object",
                "required": [
                    "email",
                    "username"
                ],
                "title": "UserCreateRequest",
                "description": "ユーザー登録時にリクエストクラス\n\nemail：メールアドレス\nusername: ユーザー名"
