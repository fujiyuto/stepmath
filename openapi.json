                "type": "object",
                "required": [
                    "message"
                ],
                "title": "MessageCreateRequest",
                "description": "メッセージ送信時のリクエストモデル\n\nmessage: メッセージ"
            },
            "UserCreateRequest": {
                "properties": {
                    "email": {
                        "type": "string",
