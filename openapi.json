                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "MessageCreateRequest": {
                "properties": {
                    "message": {
                        "type": "string",
                        "maxLength": 500,
                        "title": "Message"
                    }
